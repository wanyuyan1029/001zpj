<view class="page">
  <view class="wheel-area">
    <view class="pointer"></view>
    <view
      class="wheel-shell"
      style="transform: rotate({{rotation}}deg); transition-duration: {{spinDuration}}ms;"
    >
      <canvas
        canvas-id="wheelCanvas"
        class="wheel-canvas"
        style="width: {{canvasSize}}px; height: {{canvasSize}}px;"
        width="{{canvasSize}}"
        height="{{canvasSize}}"
      ></canvas>
    </view>
    <view class="hub">
      <text class="hub-text">{{isSpinning ? '抽取中' : 'GO'}}</text>
    </view>
  </view>

  <view class="result" wx:if="{{lastResult}}">
    <text class="result-label">本次结果</text>
    <text class="result-value">{{lastResult}}</text>
  </view>

  <view class="panel">
    <view class="panel-head">
      <view>
        <text class="panel-title">转盘选项</text>
        <text class="panel-subtitle">合计 {{totalPercent}}%，需等于 100%</text>
      </view>
      <button class="icon-button" bindtap="addOption" disabled="{{isSpinning}}">+</button>
    </view>

    <view class="status {{isValid ? 'status-ok' : 'status-warn'}}">
      {{isValid ? '百分比配置可用' : '请调整百分比，让总和等于 100%'}}
    </view>

    <view class="option-list">
      <view class="option-row" wx:for="{{options}}" wx:key="id">
        <view class="color-dot" style="background: {{item.color}};"></view>
        <input
          class="name-input"
          value="{{item.name}}"
          data-index="{{index}}"
          disabled="{{isSpinning}}"
          bindinput="onNameInput"
          placeholder="选项名称"
        />
        <input
          class="percent-input"
          type="digit"
          value="{{item.percent}}"
          data-index="{{index}}"
          disabled="{{isSpinning}}"
          bindinput="onPercentInput"
          placeholder="0"
        />
        <text class="percent-mark">%</text>
        <button
          class="delete-button"
          data-index="{{index}}"
          bindtap="removeOption"
          disabled="{{isSpinning || options.length <= 2}}"
        >×</button>
      </view>
    </view>
  </view>

  <button
    class="spin-button"
    bindtap="startSpin"
    loading="{{isSpinning}}"
    disabled="{{!isValid || isSpinning}}"
  >
    {{isSpinning ? '正在抽取' : '开始抽取'}}
  </button>
</view>
